# ╔══════════════════════════════════════════════════════════════════╗
# ║  SYSTOLAB — Environment Configuration Template                  ║
# ║                                                                  ║
# ║  Environment separation:                                         ║
# ║    Development : copy to .env, set SYSTOLAB_ENV=sandbox          ║
# ║    Staging     : copy to .env.staging, NODE_ENV=production       ║
# ║    Production  : copy to .env.prod,    NODE_ENV=production       ║
# ║                                                                  ║
# ║  Production checklist:                                           ║
# ║    ✓ All secrets ≥ 32 chars, no placeholder words               ║
# ║    ✓ SYSTOLAB_MEMORY_STORE=false                                 ║
# ║    ✓ MONGODB_URI set to Atlas/replica-set URI                    ║
# ║    ✓ SYSTOLAB_AUTH_ALLOW_DEV_GOOGLE_CREDENTIAL=false             ║
# ║    ✓ SYSTOLAB_GOOGLE_JWKS_JSON contains real JWKS                ║
# ╚══════════════════════════════════════════════════════════════════╝

# ── Runtime environment ────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4100
CLIENT_ORIGIN=http://127.0.0.1:5173

# ── MongoDB ────────────────────────────────────────────────────────────────────
# Development: leave blank to use in-memory store (SYSTOLAB_MEMORY_STORE=true).
# Staging/Production: provide a full URI with credentials and authSource.
# Example: mongodb+srv://user:pass@cluster.mongodb.net/systolab?retryWrites=true&w=majority
MONGODB_URI=
SYSTOLAB_MEMORY_STORE=true

# ── Docker / production only: MongoDB credentials ─────────────────────────────
# Used by docker-compose.prod.yml to initialise the MongoDB root user.
MONGO_ROOT_USER=systolab
MONGO_ROOT_PASSWORD=

# ── Deployment identity ────────────────────────────────────────────────────────
SYSTOLAB_ENV=sandbox
SYSTOLAB_REGION=local
SYSTOLAB_NODE_CLUSTER=local-1
SYSTOLAB_BUILD_HASH=dev

# ── API keys and admin access ──────────────────────────────────────────────────
# Development: placeholder values below are fine; they auto-rotate on every restart.
# Production: must be strong random secrets (≥ 32 chars, no placeholder words).
SYSTOLAB_DEV_API_KEY=systolab_dev_api_9f4c2a7b1x8k5m
SYSTOLAB_INTERNAL_ADMIN_KEY=
SYSTOLAB_OWNER_ADMIN_KEY=
SYSTOLAB_MANAGER_ADMIN_KEY=

# ── JWT secrets ────────────────────────────────────────────────────────────────
# User authentication JWT (access + refresh tokens).
SYSTOLAB_AUTH_JWT_SECRET=
# Admin panel JWT (separate secret, separate sessions).
SYSTOLAB_ADMIN_JWT_SECRET=

# ── Auth token settings ────────────────────────────────────────────────────────
SYSTOLAB_AUTH_ACCESS_TOKEN_MINUTES=30
SYSTOLAB_AUTH_REFRESH_TOKEN_DAYS=30
SYSTOLAB_AUTH_OTP_LENGTH=6
SYSTOLAB_AUTH_OTP_TTL_MINUTES=10
SYSTOLAB_AUTH_OTP_RESEND_COOLDOWN_SECONDS=60
SYSTOLAB_AUTH_LOCK_MINUTES=15
SYSTOLAB_AUTH_PASSWORD_RESET_MINUTES=20
SYSTOLAB_ADMIN_SESSION_HOURS=8
SYSTOLAB_ADMIN_LOGIN_MAX_ATTEMPTS=5
SYSTOLAB_ADMIN_LOCK_MINUTES=30

# ── Google sign-in ─────────────────────────────────────────────────────────────
# Production: use a locally managed JWKS JSON (not a client secret).
# Disable dev credential bypass before going live.
SYSTOLAB_GOOGLE_CLIENT_ID=
SYSTOLAB_GOOGLE_JWKS_JSON=
SYSTOLAB_AUTH_ALLOW_DEV_GOOGLE_CREDENTIAL=true

# ── Firebase (optional) ────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_JSON=

# ── Rate limits ────────────────────────────────────────────────────────────────
SYSTOLAB_GLOBAL_RATE_LIMIT_PER_MINUTE=45
SYSTOLAB_AUTH_RATE_LIMIT_PER_MINUTE=30
SYSTOLAB_SCAN_RATE_LIMIT_PER_MINUTE=8
SYSTOLAB_SCAN_STATUS_RATE_LIMIT_PER_MINUTE=120
SYSTOLAB_PUBLIC_API_RATE_LIMIT_PER_MINUTE=120
SYSTOLAB_PUBLIC_API_DAILY_QUOTA=1000

# ── Scanner / crawl safety ─────────────────────────────────────────────────────
SYSTOLAB_CRAWL_TIMEOUT_MS=12000
SYSTOLAB_CRAWL_MAX_BYTES=1500000
SYSTOLAB_CRAWL_MAX_REDIRECTS=5
SYSTOLAB_MAX_INTERNAL_PAGES=5

# ── Async scan worker (Phase 4) ────────────────────────────────────────────────
# POST /api/scans now enqueues jobs; the worker consumes them.
SYSTOLAB_SCAN_WORKER_ENABLED=true
SYSTOLAB_SCAN_WORKER_INTERVAL_MS=3000
SYSTOLAB_SCAN_WORKER_BATCH_SIZE=2
SYSTOLAB_SCAN_WORKER_LOCK_TIMEOUT_MS=300000

# ── Monitoring and IIRE workers ────────────────────────────────────────────────
SYSTOLAB_MONITORING_WORKER_ENABLED=true
SYSTOLAB_MONITORING_WORKER_INTERVAL_MS=60000
SYSTOLAB_MONITORING_WORKER_BATCH_SIZE=3
SYSTOLAB_IIRE_WORKER_ENABLED=true
SYSTOLAB_IIRE_WORKER_INTERVAL_MS=300000

# ── Playwright headless rendering (Phase 5) ────────────────────────────────────
# Disabled by default. Enable only if Playwright/Chromium binaries are installed
# (the Docker API image includes Chromium via apk).
SYSTOLAB_PLAYWRIGHT_ENABLED=false
SYSTOLAB_PLAYWRIGHT_TIMEOUT_MS=15000
SYSTOLAB_PLAYWRIGHT_VIEWPORT_WIDTH=1280
SYSTOLAB_PLAYWRIGHT_VIEWPORT_HEIGHT=800
# Set to true to capture full-page screenshots for every crawled sub-page.
# Warning: significantly increases storage and scan time.
SYSTOLAB_PLAYWRIGHT_SCREENSHOT_ALL_PAGES=false

# ── Artifact storage (Phase 5) ─────────────────────────────────────────────────
# Leave SYSTOLAB_ARTIFACT_DIR blank to store screenshots as base64 in MongoDB.
# In Docker, the runner mounts /data/artifacts — set this to that path.
SYSTOLAB_ARTIFACT_DIR=
# Secret for HMAC-SHA256 signed artifact access URLs. Must be strong in production.
SYSTOLAB_ARTIFACT_SECRET=
# Signed URL lifetime (default: 1 hour).
SYSTOLAB_ARTIFACT_TOKEN_TTL_MS=3600000

# ── Backup and disaster recovery (Phase 7) ────────────────────────────────────
# Directory where mongodump outputs are stored. In Docker, mount a persistent
# volume and set this to the mount path (default: /data/backups).
SYSTOLAB_BACKUP_DIR=/data/backups
# Number of days to retain completed backups before pruning (0 = keep forever).
SYSTOLAB_BACKUP_MAX_AGE_DAYS=7
# Paths to MongoDB Database Tools binaries. Must be installed separately.
# https://www.mongodb.com/try/download/database-tools
SYSTOLAB_BACKUP_MONGODUMP_PATH=mongodump
SYSTOLAB_BACKUP_MONGORESTORE_PATH=mongorestore
# Comma-separated list of collections to back up (empty = all collections).
# Example: systolab.snapshots,systolab.authusers
SYSTOLAB_BACKUP_COLLECTIONS=

# ── Governance automation (Phase 10) ──────────────────────────────────────────
# Retention worker: sweeps expired records according to defined policies.
SYSTOLAB_RETENTION_WORKER_ENABLED=true
# How often the retention worker runs (ms). Default: 1 hour.
SYSTOLAB_RETENTION_WORKER_INTERVAL_MS=3600000
# Max records processed per policy per sweep cycle.
SYSTOLAB_RETENTION_WORKER_BATCH_SIZE=100
# Default retention window (days) used when no specific policy is set.
SYSTOLAB_RETENTION_DEFAULT_DAYS=90
# Maximum payload size (bytes) stored in quarantine records. Default: 64KB.
SYSTOLAB_QUARANTINE_MAX_PAYLOAD_BYTES=65536
# Minimum quality score (0-100) for a scoring algorithm version to pass quality check.
SYSTOLAB_BENCHMARK_MIN_QUALITY_SCORE=60
# Maximum allowed mean score drift (in points) when publishing a new scoring version.
SYSTOLAB_BENCHMARK_MAX_DRIFT=15
# Directory where compliance exports (GDPR, SOC2) are written as JSON files.
# Leave blank to skip filesystem writes (metadata is still tracked in MongoDB).
SYSTOLAB_COMPLIANCE_EXPORT_DIR=

# ── White-label / billing (Phase 11) ─────────────────────────────────────────
# Email provider: sendgrid | mailgun | resend (leave blank to simulate/log only)
SYSTOLAB_EMAIL_PROVIDER=
# API key for the email provider (SendGrid API key, Mailgun API key, or Resend API key)
SYSTOLAB_EMAIL_API_KEY=
# Default From address and display name for outbound emails
SYSTOLAB_EMAIL_FROM_ADDRESS=noreply@systolab.app
SYSTOLAB_EMAIL_FROM_NAME=Systolab
# Mailgun-only: your sending domain (e.g. mg.yourcompany.com)
SYSTOLAB_EMAIL_MAILGUN_DOMAIN=

# Webhook delivery worker: retries failed webhook deliveries.
SYSTOLAB_WEBHOOK_WORKER_ENABLED=true
# How often the worker polls for pending deliveries (ms). Default: 30s.
SYSTOLAB_WEBHOOK_WORKER_INTERVAL_MS=30000
# Max deliveries processed per worker cycle.
SYSTOLAB_WEBHOOK_WORKER_BATCH_SIZE=20

# ── Event bus / delivery worker (Phase 9) ────────────────────────────────────
# Background worker that retries failed event deliveries and processes the queue.
SYSTOLAB_EVENT_BUS_WORKER_ENABLED=true
# How often the worker polls for pending deliveries (ms). Default: 5s.
SYSTOLAB_EVENT_BUS_WORKER_INTERVAL_MS=5000
# Max deliveries processed per worker cycle.
SYSTOLAB_EVENT_BUS_WORKER_BATCH_SIZE=20
# Max delivery attempts before a record is moved to dead-letter. Default: 3.
SYSTOLAB_EVENT_BUS_MAX_RETRIES=3

# ── Observability (Phase 8) ────────────────────────────────────────────────────
# Structured JSON log level (debug | info | warn | error). Default: info.
# In production, keep at info or warn to reduce log volume.
SYSTOLAB_LOG_LEVEL=info
# Optional bearer key for the GET /metrics Prometheus endpoint.
# Leave blank to allow unauthenticated scraping (e.g., in private networks).
# Example: openssl rand -hex 32
SYSTOLAB_METRICS_AUTH_KEY=

# ── Frontend (Vite build-time vars) ───────────────────────────────────────────
# In production (Docker), these are passed as --build-arg to the web Dockerfile.
# For local dev, Vite proxies /api to the API server automatically.
VITE_API_URL=http://127.0.0.1:4100
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Production: image tags for docker-compose.prod.yml ────────────────────────
# Override to pin specific images instead of building locally.
# API_IMAGE=ghcr.io/your-org/systolab-api:v1.2.3
# WEB_IMAGE=ghcr.io/your-org/systolab-web:v1.2.3
